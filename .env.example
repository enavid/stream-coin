# ==============================================================================
# stream-coin — Environment Variables
# cp .env.example .env  →  fill in passwords and domain
# ==============================================================================

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080
RUST_LOG=info
LOG_FORMAT=json

# ------------------------------------------------------------------------------
# Auth (JWT + Admin account)
# Generate a strong random value for JWT_SECRET in production.
# ADMIN_USERNAME / ADMIN_PASSWORD enable POST /v1/auth/token.
# TABDEAL_API_KEY is a dev shortcut; in production set via API:
#   POST /v1/admin/exchanges/tabdeal/credentials { "api_key": "..." }
# ------------------------------------------------------------------------------
JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
TABDEAL_API_KEY=

# ------------------------------------------------------------------------------
# Database (PostgreSQL + TimescaleDB)
# POSTGRES_USER/PASSWORD/DB configure the container (compose/postgres.yml).
# DATABASE_URL is what the engine connects with — keep credentials in sync.
# ------------------------------------------------------------------------------
POSTGRES_USER=stream_coin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=stream_coin
DATABASE_URL=postgresql://stream_coin:change-me@localhost:5432/stream_coin

# ------------------------------------------------------------------------------
# Order Manager Safety Controls
# DRY_RUN=true means orders are logged but never sent to the exchange.
# ------------------------------------------------------------------------------
DRY_RUN=true
MIN_CONFIDENCE=0.7
MAX_POSITION_SIZE=1000
DEFAULT_ORDER_QUANTITY=100
CIRCUIT_BREAKER_MAX_ORDERS=10
CIRCUIT_BREAKER_WINDOW_SECS=60

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# Kafka (app connection)
# dev (host):    localhost:9092
# prod (docker): kafka:9094
# ------------------------------------------------------------------------------
KAFKA_URL=localhost:9092
KAFKA_TOPIC_PRICES=prices

# ------------------------------------------------------------------------------
# Kafka Version (applies to all Confluent images)
# ------------------------------------------------------------------------------
KAFKA_VERSION=8.0.0

# ------------------------------------------------------------------------------
# Kafka Broker
# ------------------------------------------------------------------------------
KAFKA_NODE_ID=1
KAFKA_CLUSTER_ID=bmpTNWtoR4bbWx-BH6nGLf

# Public IP or domain of this server (used for EXTERNAL SSL listener on :9095)
KAFKA_ADVERTISED_HOST=localhost

KAFKA_REPLICATION_FACTOR=1
KAFKA_MIN_ISR=1

KAFKA_HEAP_OPTS=-Xmx1G -Xms1G
KAFKA_NETWORK_THREADS=3
KAFKA_IO_THREADS=8

KAFKA_LOG_RETENTION_HOURS=168
KAFKA_LOG_RETENTION_BYTES=1073741824

KAFKA_AUTO_CREATE_TOPICS=true
KAFKA_COMPRESSION_TYPE=producer
KAFKA_LOG_LEVEL=INFO

KAFKA_MEMORY_LIMIT=2G
KAFKA_CPU_LIMIT=2.0
KAFKA_MEMORY_RESERVATION=1G
KAFKA_CPU_RESERVATION=1.0

# ------------------------------------------------------------------------------
# Kafka SSL (internal mTLS — auto-generated on first run into ./certs/)
# ------------------------------------------------------------------------------
KAFKA_SSL_KEYSTORE_PASSWORD=changeit
KAFKA_SSL_TRUSTSTORE_PASSWORD=changeit
KAFKA_SSL_KEY_PASSWORD=changeit

# ------------------------------------------------------------------------------
# Schema Registry
# ------------------------------------------------------------------------------
SCHEMA_REGISTRY_MEMORY_LIMIT=512M
SCHEMA_REGISTRY_CPU_LIMIT=0.5
SCHEMA_REGISTRY_MEMORY_RESERVATION=256M
SCHEMA_REGISTRY_CPU_RESERVATION=0.25

# ------------------------------------------------------------------------------
# Kafka Connect
# ------------------------------------------------------------------------------
KAFKA_CONNECT_MEMORY_LIMIT=2G
KAFKA_CONNECT_CPU_LIMIT=1.0
KAFKA_CONNECT_MEMORY_RESERVATION=1G
KAFKA_CONNECT_CPU_RESERVATION=0.5

# ------------------------------------------------------------------------------
# REST Proxy
# ------------------------------------------------------------------------------
REST_PROXY_MEMORY_LIMIT=512M
REST_PROXY_CPU_LIMIT=0.5
REST_PROXY_MEMORY_RESERVATION=256M
REST_PROXY_CPU_RESERVATION=0.25

# ------------------------------------------------------------------------------
# Flink
# ------------------------------------------------------------------------------
FLINK_JM_MEMORY=1600m
FLINK_TM_MEMORY=1728m
FLINK_PARALLELISM=1
FLINK_TASK_SLOTS=10
FLINK_CHECKPOINT_INTERVAL=30000

FLINK_JM_MEMORY_LIMIT=2G
FLINK_JM_CPU_LIMIT=1.0
FLINK_JM_MEMORY_RESERVATION=1G
FLINK_JM_CPU_RESERVATION=0.5

FLINK_TM_MEMORY_LIMIT=2G
FLINK_TM_CPU_LIMIT=2.0
FLINK_TM_MEMORY_RESERVATION=1G
FLINK_TM_CPU_RESERVATION=1.0

# ------------------------------------------------------------------------------
# Kafka UI (accessible at http://localhost:8083 for dev)
# ------------------------------------------------------------------------------
KAFKA_UI_CLUSTER_NAME=stream-coin
KAFKA_UI_READONLY=false
KAFKA_UI_USERNAME=admin
KAFKA_UI_PASSWORD=changeme
